{
	"info": {
		"_postman_id": "bfc-api-collection-v1",
		"name": "Beijing FC Management System API",
		"description": "Postman API Collection for Beijing FC RESTful Endpoints (Laravel Sanctum Auth)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@bfc.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/login",
							"host": ["{{base_url}}"],
							"path": ["api", "login"]
						}
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/api/logout",
							"host": ["{{base_url}}"],
							"path": ["api", "logout"]
						}
					}
				}
			]
		},
		{
			"name": "Dashboard",
			"item": [
				{
					"name": "Get Dashboard Data",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/api/dashboard",
							"host": ["{{base_url}}"],
							"path": ["api", "dashboard"]
						}
					}
				}
			]
		},
		{
			"name": "Stored Procedures",
			"item": [
				{
					"name": "Get Player Stats (SP)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/api/sp/player/1/stats",
							"host": ["{{base_url}}"],
							"path": ["api", "sp", "player", "1", "stats"]
						}
					}
				},
				{
					"name": "Get Team Squad (SP)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/api/sp/team/1/squad",
							"host": ["{{base_url}}"],
							"path": ["api", "sp", "team", "1", "squad"]
						}
					}
				},
				{
					"name": "Get Upcoming Matches (SP)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/api/sp/matches/upcoming?limit=5",
							"host": ["{{base_url}}"],
							"path": ["api", "sp", "matches", "upcoming"],
							"query": [{ "key": "limit", "value": "5" }]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000"
		},
		{
			"key": "auth_token",
			"value": ""
		}
	]
}
